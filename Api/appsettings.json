{
  "ConnectionStrings": {
    "WorkoutLogDatabase": "Host=localhost;Port=5432;Database=workoutlog;Username=workoutlog;Password=workoutlog"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "WorkoutLog",
      "Audience": "WorkoutLog.Client",
      "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS",
      "AccessTokenMinutes": 15
    },
    "RefreshToken": {
      "CookieName": "refreshToken",
      "RefreshTokenDays": 7,
      "CookiePath": "/api/auth"
    },
    "PasswordReset": {
      "IncludeDebugResetToken": false
    },
    "BootstrapAdmin": {
      "Enabled": false,
      "Email": "admin@workoutlog.local",
      "Username": "admin",
      "Password": "CHANGE_ME_TO_A_STRONG_BOOTSTRAP_ADMIN_PASSWORD"
    }
  },
  "UserExerciseStats": {
    "Maintenance": {
      "RecomputeAllOnStartup": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
