meta {
  name: Reset Password
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/reset-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "REPLACE_WITH_RESET_TOKEN",
    "identifier": "demo.user@example.com",
    "newPassword": "DemoPass456"
  }
}
