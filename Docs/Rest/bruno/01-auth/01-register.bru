meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "canaan@example.com",
    "username": "demo.user",
    "password": "DemoPass123"
  }
}

vars:pre-request {
  baseUrl: https://localhost:8081
}
