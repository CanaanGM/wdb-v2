POSTGRES_DB=workoutlog
POSTGRES_USER=workoutlog
POSTGRES_PASSWORD=workoutlog
POSTGRES_PORT=5432
API_HTTP_PORT=8080
API_HTTPS_PORT=8081
HTTPS_CERT_PASSWORD=WorkoutLogDev!2026
AUTH_JWT_ISSUER=WorkoutLog
AUTH_JWT_AUDIENCE=WorkoutLog.Client
# Required: replace this placeholder before startup.
# The API now fails fast in every environment (including Development) if this value is unchanged.
AUTH_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
AUTH_JWT_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_REFRESH_DAYS=7
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_PASSWORD_RESET_INCLUDE_DEBUG_TOKEN=false
AUTH_BOOTSTRAP_ADMIN_ENABLED=false
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@workoutlog.local
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_BOOTSTRAP_ADMIN_PASSWORD
